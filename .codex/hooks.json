{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "/home/pi/cairn/.codex/hooks/block-dangerous.sh",
            "timeout": 10,
            "statusMessage": "Checking command safety"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "/home/pi/cairn/.codex/hooks/track-failures.sh",
            "timeout": 10,
            "statusMessage": "Checking repeated failures"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/pi/cairn/.codex/hooks/check-cycle-cap.sh",
            "timeout": 30,
            "statusMessage": "Checking cycle limits"
          }
        ]
      }
    ]
  }
}

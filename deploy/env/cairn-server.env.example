# Cairn server environment — copy to /home/pi/cairn-data/cairn-server.env
# Keep this file outside the git repo; never commit real values.

# Fastify bind address and port.
# HOST=127.0.0.1 keeps the API on loopback; Caddy proxies from outside.
HOST=127.0.0.1
PORT=3100

# SQLite database path (outside the repo so it survives redeploys).
# DB_PATH   — read by Fastify runtime (server/src/index.ts).
# CAIRN_DB_PATH — read by Drizzle migration tool (server/drizzle.config.ts).
# Both must point to the same file.
DB_PATH=/home/pi/cairn-data/cairn.sqlite3
CAIRN_DB_PATH=/home/pi/cairn-data/cairn.sqlite3

# Optional — LLM proxy for push-reply and thread-draft features.
# Leave unset to run in fully deterministic mode.
# LLM_PROXY_BASE_URL=http://localhost:8000

# Optional — Telegram bot token for push notifications.
# TELEGRAM_BOT_TOKEN=<your-bot-token>
# TELEGRAM_CHAT_ID=<your-chat-id>

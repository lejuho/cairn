# ============================================================
# Multi-Agent Coding Environment - .gitignore additions
# ============================================================
# 이 파일의 내용을 프로젝트 루트 .gitignore에 append.
# 두 영역으로 구성: (1) 필수 ignore, (2) 정책 선택 영역.

# ------------------------------------------------------------
# (1) 필수 ignore — hook 임시 파일 및 로컬 설정
# ------------------------------------------------------------

# check-context-budget.sh가 cycle별로 생성하는 카운터 파일
.review/cycle-*/.read-counter

# (선택) cycle별 환경 변수 override 파일 — 사용 시 git 추적 금지
.review/cycle-*/.cycle-env

# track-failures.sh의 시스템 임시 로그
/tmp/claude-failures-*.log

# Claude Code 로컬 권한 (사용자별 — 절대경로/MCP 토큰 포함 가능)
.claude/settings.local.json

# ------------------------------------------------------------
# (2) 정책 선택 영역 — .review/ 디렉터리 추적 정책
# ------------------------------------------------------------
# 아래 3개 옵션 중 프로젝트 정책에 맞는 것을 선택해 주석 해제.
# 옵션 미선택 시 기본은 "옵션 A (전체 추적)".

# 옵션 A: 전체 추적 — 권장 (개인 프로젝트, 팀 협업)
#   장점: cycle history 공유, Hansei 추출용 데이터 보존, 재현 가능
#   단점: repo 크기 증가, advisor 응답 노출
#   (위 임시 파일들만 ignore하고 .review/ 내 나머지는 자동 추적)

# 옵션 B: cycle 산출물 전체 미추적 — 로컬 작업 전용
#   장점: repo 크기 최소
#   단점: cycle history 공유 불가, 다른 환경에서 재개 어려움
# .review/cycle-*/
# (단, _templates/는 유지)
# !.review/_templates/

# 옵션 C: 부분 추적 — advisor-feedback만 미추적
#   장점: plan/review history는 공유, advisor 응답은 로컬만
#   사용 시점: advisor 응답이 민감 정보 포함하거나 토큰 비용으로 외부 공유 부담
# .review/cycle-*/advisor-feedback/

# ------------------------------------------------------------
# 추가 권장 (이미 있으면 중복 무시됨)
# ------------------------------------------------------------

# IDE/OS 임시 파일 — 프로젝트 정책에 따라 추가
# .DS_Store
# .idea/
# .vscode/

# Node / build output
node_modules/
dist/
coverage/
.vite/

# Local generated runtime/agent output
/logs/
/scripts/

# Local environment and databases
.env
.env.*
*.sqlite
*.sqlite3
*.db

# Local GCal OAuth tokens and credentials
.cairn/
